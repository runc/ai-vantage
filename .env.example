# Web (Next.js)
GRAPH_DATA_SOURCE=static
# GRAPH_DATA_SOURCE=api
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database — default: local SQLite via libsql (no install needed)
# Omit DATABASE_URL to use: file:<repo>/.local/ai-vantage.db
# DATABASE_URL=file:.local/ai-vantage.db

# Optional: Turso / remote libsql
# DATABASE_URL=libsql://your-database.turso.io
# LIBSQL_AUTH_TOKEN=

# Optional: PostgreSQL (production or local postgres)
# DATABASE_URL=postgresql://ai_vantage:ai_vantage@localhost:5432/ai_vantage

API_PORT=3001
