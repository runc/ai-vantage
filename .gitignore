# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (pnpm workspace: every package may have node_modules/)
node_modules/

# pnpm
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-debug.log*

# other package managers (this repo uses pnpm)
package-lock.json
yarn.lock

# testing
coverage/

# vitest
.vite/

# next.js
.next/
out/

# production / compiled output
build/
dist/

# local SQLite (libsql) and dev artifacts
.local/
.seed-export/

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (opt-in via .env.example if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# eslint
.eslintcache

# IDE / editor
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*~

# local tool overrides (permissions, machine-specific config)
.qoder/
.antigravitycli/

# turborepo (if adopted later)
.turbo/
